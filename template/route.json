{
  "route-server": {
    "rules": [
      {
        "action": "route",
        "outbound": "direct",
        "ip_cidr": [
              ${WG_HOSTIPS}
            ]
      },
      {
        "action": "route",
        "outbound": "wg-ep",
        "ip_cidr": [
          ${WG_SUBNET}
        ]
      },
      {
        "auth_user": [
          "warp"
        ],
        "action": "route",
        "outbound": "wg-ep"
      }
    ],
    "rule_set": [],
    "default_domain_resolver": "local",
    "final": "direct"
  },
  "route-client": {
    "rules": [
      {
        "action": "sniff"
      },
      {
        "action": "hijack-dns",
        "protocol": "dns"
      },
      {
        "domain_suffix": [
          ${DOMAIN_LOCAL_STR}
        ],
        "outbound": "direct"
      }
    ],
    "auto_detect_interface": true,
    "default_domain_resolver": "local",
    "final": "auto-proxy"
  }
}