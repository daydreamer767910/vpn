{
  "endpoint-server":[
    {
      "type": "wireguard",
      "tag": "wg-ep",
      "mtu": 1280,
      "address": [${WG_HOSTIPS}],
      "private_key": "${WG_SRV_PRIVATE_KEY}",
      "listen_port": ${WG_PORT},
      "system": false,
      "udp_timeout": "5m",
      "peers": [
        {
          "public_key": "${WG_CLNT_PUBLIC_KEY}",
          "allowed_ips": ["0.0.0.0/0","::/0"]
        }
      ]
    }
  ],
  "endpoint-client":[
    {
      "type": "wireguard",
      "tag": "wg-ep-cn",
      "detour": "auto-proxy",
      "name": "wg0",
      "system": false,
      "mtu": 1280,
      "address": ["10.0.0.2/32","fd42:42:42::2/64"],
      "private_key": "${WG_CLNT_PRIVATE_KEY}",
      "peers": [
        {
          "address": "${DOMAIN}", 
          "port": ${WG_PORT},
          "public_key": "${WG_SRV_PUBLIC_KEY}",
          "allowed_ips": ["0.0.0.0/0","::/0"],
          "persistent_keepalive_interval":25
        }
      ]
    },
    {
      "type": "wireguard",
      "tag": "wg-ep",
      "name": "wg1",
      "system": false,
      "mtu": 1280,
      "address": ["10.0.0.2/32","fd42:42:42::2/64"],
      "private_key": "${WG_CLNT_PRIVATE_KEY}",
      "peers": [
        {
          "address": "${DOMAIN}", 
          "port": ${WG_PORT},
          "public_key": "${WG_SRV_PUBLIC_KEY}",
          "allowed_ips": ["0.0.0.0/0","::/0"],
          "persistent_keepalive_interval":25
        }
      ]
    }
  ]
}