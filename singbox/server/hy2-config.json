{
  "log": { "level": "info" },
  "inbounds": [
    {
      "type": "hysteria2",
      "tag": "hy2-in",
      "listen": "::",
      "listen_port": 443,
      "obfs": {
        "type": "salamander",
        "password": "cry_me_a_r1ver"
      },
      "masquerade": {
        "type": "file",
        "directory": "file:///oumass/auth"
      },
      "users": [ { "name": "default", "password": "mypassword" } ],
      "tls": { 
        "enabled": true,
        "certificate_path": "/etc/singbox/fullchain.pem",
        "key_path": "/etc/singbox/privkey.pem"
      }
    }
  ],
  "outbounds": [ { "type": "direct" } ],
  "dns": {
    "strategy": "ipv4_only"
  }
}
