{
  "log": { "level": "info" },
  "inbounds": [
    {
      "type": "tun",
      "tag": "tun-in",
      "interface_name": "tun0",
      "address": ["172.31.255.2/30"],
      "auto_route": true,
      "strict_route": true,
      "stack": "system"
    }
  ],
  "outbounds": [
    {
      "type": "hysteria2",
	    "tag": "proxy",
      "server": "oumass.duckdns.org",
      "server_port": 8443,
	    "obfs": {
        "type": "salamander",
        "password": "cry_me_a_r1ver"
      },
      "masquerade": {
        "type": "file",
        "directory": "file:///oumass/auth"
      },
      "password": "mypassword",
      "tls": { "enabled": true, "server_name": "oumass.duckdns.org" }
    },
    {
      "type": "direct",
      "tag": "direct"
    }
  ],
  "dns": {
    "servers": [
      {
        "address": "223.5.5.5",
        "tag": "direct-dns"
      },
      {
        "address": "https://1.1.1.1/dns-query",
        "tag": "proxy-dns",
        "detour": "proxy"
      }
    ],
    "rules": [
      {
        "rule_set": "geoip-cn",
        "server": "direct-dns"
      }
    ],
    "final": "proxy-dns",
    "strategy": "prefer_ipv4",
    "independent_cache": true
  },
  "route": {
    "rule_set": [
      {
        "type": "remote",
        "tag": "geoip-cn",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/Loyalsoldier/geoip/release/Country.mmdb",
        "download_detour": "proxy",
        "update_interval": "24h"
      },
      {
        "type": "remote",
        "tag": "geosite-cn",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/Loyalsoldier/v2ray-rules-dat/release/geosite.dat",
        "download_detour": "proxy",
        "update_interval": "24h"
      }
    ],
    "rules": [
      {
        "rule_set": "geosite-cn",
        "outbound": "direct",
        "domain_resolver": {
          "server": "direct-dns"
        }
      },
      {
        "rule_set": "geoip-cn",
        "outbound": "direct",
        "domain_resolver": {
          "server": "direct-dns"
        }
      },
      {
        "outbound": "proxy",
        "domain_resolver": {
          "server": "proxy-dns"
        }
      }
    ],
    "final": "proxy"
  }
}
